# ---- Telegram ----
BOT_TOKEN=
BOT_USERNAME=StellaBot

# Список суперадминов через запятую (Telegram user_id)
SUPERADMIN_IDS=

# ---- Веб-панель ----
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
# Секрет сессий. Сгенерировать: python -c "import os; print(os.urandom(32).hex())"
# Если не задать — сгенерируется автоматически (но сбросится при перезапуске)
FLASK_SECRET=

# Хост и порт Flask (при прямом запуске без gunicorn)
WEB_HOST=0.0.0.0
WEB_PORT=5000

# ---- База данных ----
# По умолчанию SQLite в папке data/
# DATABASE_URL=sqlite:///data/app.db
# Для PostgreSQL:
# DATABASE_URL=postgresql://user:password@host/dbname

# ---- Пути ----
DATA_DIR=data
LOG_DIR=logs

# ---- ИИ (DeepSeek) ----
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ---- Апелляции ----
# APPEALS_CHAT_ID=

# ---- Окружение ----
ENV=development
LOG_LEVEL=INFO
TIMEZONE=Europe/Moscow

# ---- Gunicorn (продакшн) ----
GUNICORN_BIND=127.0.0.1:8000
GUNICORN_WORKERS=2
GUNICORN_TIMEOUT=30
